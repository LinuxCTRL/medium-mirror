# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   often managed by the project's users and not the library itself.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, pipenv managed virtual environments are usually
#   not shared with others, so it is recommended to ignore them.
#   However, if you're working on a top-level package, it is recommended to keep Pipfile.lock in git.
#Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipenv, see https://pdm.fming.dev/#usage
.pdm-python
pdm.lock
.pdm-plugins/

